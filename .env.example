# Variáveis de ambiente do AparecidaShop.
#
# Nenhuma delas é necessária para rodar o projeto nesta etapa (ainda não há
# banco de dados, API externa ou autenticação implementados). Este arquivo
# documenta o que será usado nas próximas etapas — copie para `.env.local`
# e preencha quando essas integrações forem implementadas.

# Banco de dados (uso futuro — PostgreSQL)
DATABASE_URL=

# API externa (uso futuro)
NEXT_PUBLIC_API_BASE_URL=

# Autenticação (uso futuro)
AUTH_SECRET=
